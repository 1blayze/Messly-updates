VITE_FRIEND_REQUESTS_ENABLED=true

# Spotify OAuth (Connections)
# Configure in Spotify Developer Dashboard with the same redirect URI below.
VITE_SPOTIFY_CLIENT_ID=
# Example (desktop deep link): messly://callback
# Example (web local): http://localhost:5173/
VITE_SPOTIFY_REDIRECT_URI=

# Supabase Configuration (Required for DB + Edge Functions)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# Prefer publishable key for client access (new projects)
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Legacy anon key fallback (optional)
VITE_SUPABASE_ANON_KEY=your_anon_key
# Calls em DEV: usa Edge Functions apenas se esta flag estiver ativa (1/true/yes).
VITE_CALLS_USE_EDGE_FUNCTIONS_IN_DEV=false
# WebRTC call networking
# JSON array of RTCIceServer objects. Keep TURN credentials only in trusted environments.
VITE_WEBRTC_ICE_SERVERS_JSON=
# all | relay
VITE_WEBRTC_ICE_TRANSPORT_POLICY=all
# Force TURN-only routing when P2P is blocked.
VITE_WEBRTC_FORCE_RELAY=false
# If connection fails on all policy, trigger ICE restart with relay fallback.
VITE_WEBRTC_RELAY_FALLBACK_ENABLED=true
# balanced | max-bundle | max-compat
VITE_WEBRTC_BUNDLE_POLICY=balanced
# require | negotiate
VITE_WEBRTC_RTCP_MUX_POLICY=require
VITE_WEBRTC_ICE_CANDIDATE_POOL_SIZE=8
VITE_WEBRTC_ICE_GATHERING_TIMEOUT_MS=15000
VITE_WEBRTC_CONNECTION_TIMEOUT_MS=25000
VITE_WEBRTC_VERBOSE_LOGGING=false
# Canonical public domains
VITE_MESSLY_API_URL=http://localhost:8788
VITE_MESSLY_GATEWAY_URL=ws://localhost:8788/gateway
VITE_MESSLY_CDN_URL=
VITE_MESSLY_ASSETS_URL=
# Cloudflare Pages (producao) - sobrescreva no dashboard do Pages
# VITE_MESSLY_API_URL=https://messly.site
# VITE_MESSLY_AUTH_API_URL=https://messly.site
# VITE_MESSLY_GATEWAY_URL=wss://gateway.messly.site/gateway
# VITE_MESSLY_CDN_URL=https://messly.site
# VITE_MESSLY_ASSETS_URL=https://messly.site
# Optional explicit auth API URL. If unset, the client uses VITE_MESSLY_API_URL (or API default).
# Gateway-derived auth URL is only used for local gateway hosts.
VITE_MESSLY_AUTH_API_URL=http://localhost:8788
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Edge Functions (recommended): legacy service_role JWT
# Get from: supabase projects api-keys (id=service_role)
MESSLY_SERVICE_ROLE_JWT=your_legacy_service_role_jwt

# Edge Functions security / auth
# CORS allowlist (production): comma-separated origins
ALLOWED_ORIGINS=https://www.messly.site,https://messly.site
# Legacy alias supported by older functions
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Allow Electron app:///file:// and loopback desktop origins (http://127.0.0.1:<port>) when enabled
ALLOW_ELECTRON_ORIGIN=false
# Only enable credentials if you really need cookies on cross-origin requests
CORS_ALLOW_CREDENTIALS=false
# Supabase public key used by edge functions for RLS-scoped reads
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Legacy anon key fallback
SUPABASE_ANON_KEY=your_anon_key

# Optional distributed rate limiting (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Realtime Gateway (Node)
MESSLY_GATEWAY_PORT=8788
MESSLY_GATEWAY_SHARD_COUNT=3
# Leave unset only if this node deve atender apenas este shard.
# Use 0..MESSLY_GATEWAY_SHARD_COUNT-1 para fixar shard local.
MESSLY_GATEWAY_SHARD_INDEX=
MESSLY_GATEWAY_EVENT_CHANNEL=messly:eventbus
MESSLY_GATEWAY_METRICS_PATH=/metrics

# Redis (para presence/typing/fanout/event-bus em produção)
MESSLY_REDIS_URL=redis://127.0.0.1:6379
MESSLY_PRESENCE_TTL_SECONDS=120
MESSLY_TYPING_TTL_MS=5000

# Auth / OTP
# Configure email delivery in Supabase Auth -> SMTP Settings.
MESSLY_AUTH_OTP_TTL_SECONDS=600
MESSLY_AUTH_OTP_MAX_ATTEMPTS=5

# Registration anti-abuse (Cloudflare Turnstile + risk limits)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
REGISTRATION_IP_LIMIT_MAX=3
REGISTRATION_IP_LIMIT_WINDOW_HOURS=24
CAPTCHA_FAIL_LIMIT=5
CAPTCHA_FAIL_WINDOW_MINUTES=10
CAPTCHA_BLOCK_HOURS=24
FINGERPRINT_LIMIT_MAX=2
FINGERPRINT_LIMIT_WINDOW_HOURS=24
REGISTRATION_LEASE_TTL_MINUTES=20
ENABLE_DISPOSABLE_EMAIL_BLOCK=true
FINGERPRINT_DISTINCT_IP_THRESHOLD=4
IP_DISTINCT_FINGERPRINT_THRESHOLD=6
DOMAIN_BURST_THRESHOLD=8
MAX_CORRELATION_SAMPLE=120
CORRELATION_WINDOW_MINUTES=60
SUSPICIOUS_EVENT_WINDOW_HOURS=24
SUSPICIOUS_REINCIDENCE_THRESHOLD=2

# Optional GeoIP providers for login location detection
# Recommended: set IPINFO_TOKEN in production. IPAPI_KEY is used as fallback.
IPINFO_TOKEN=
IPAPI_KEY=

# R2 Configuration (Backend)
R2_BUCKET=messly-media
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_REGION=auto
R2_FORCE_PATH_STYLE=true

# (Opcional) Base publica do R2 (deixe vazio para modo privado)
# Ex: https://<accountId>.r2.cloudflarestorage.com/messly-media
VITE_R2_PUBLIC_BASE_URL=
MESSLY_CDN_URL=https://messly.site

# Chat media pipeline flags
VITE_CHAT_KEEP_ORIGINAL_UPLOADS=false
VITE_CHAT_E2EE_ENABLED=false

# Desktop app updates (Electron / electron-updater)
# O app publicado consulta GitHub Releases configurado via electron-builder (repo publico de updates).
# Nao coloque token do GitHub no cliente.
# Provedor oficial: electron-updater. Fallback legado: github-api.
MESSLY_UPDATER_PROVIDER=electron-updater
MESSLY_UPDATER_OWNER=1blayze
MESSLY_UPDATER_REPO=Messly-updates
# Opcional para repos privados / limite da API do GitHub (somente backend/main process).
MESSLY_UPDATER_TOKEN=
# Debug temporario no app instalado: habilita DevTools no build empacotado.
# Defina false para voltar ao bloqueio de DevTools em producao.
MESSLY_ENABLE_PACKAGED_DEVTOOLS=true
# (Opcional) Ativa updater em desenvolvimento (vite/electron local)
AUTO_UPDATE_ENABLE_IN_DEV=false
# (Opcional) Em build instalado, verifica update ao abrir e aplica automaticamente se houver.
AUTO_UPDATE_INSTALL_ON_STARTUP=true
# (Opcional) Intervalo de verificacao automatica em ms (padrao: 30 min)
AUTO_UPDATE_CHECK_INTERVAL_MS=1800000

# Windows Firewall bootstrap (Electron main + NSIS)
# Managed inbound rule name for installed Messly.exe
MESSLY_FIREWALL_RULE_NAME=Messly Private Network Access
# Keep private by default; allow public only by explicit opt-in.
MESSLY_FIREWALL_PROFILE=private
MESSLY_FIREWALL_ALLOW_PUBLIC_PROFILE=false
# Verbose main-process firewall logs (recommended only for diagnostics)
MESSLY_FIREWALL_VERBOSE_LOGS=false
# Optional startup snapshot of netsh/firewall state in main logs
MESSLY_WINDOWS_NETWORK_DIAGNOSTICS_ON_STARTUP=false
