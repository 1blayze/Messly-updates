{
  "name": "messly",
  "private": true,
  "productName": "Messly",
  "version": "0.0.22",
  "author": "Mackstony Labs",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:gateway": "node scripts/dev-gateway.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:electron:main": "node scripts/dev-electron-main.mjs",
    "dev:electron:services": "concurrently --names WEB,ELECTRON --prefix \"[{time}] ★ {name}\" --timestamp-format \"HH:mm:ss\" --kill-others-on-fail \"node scripts/dev-web.mjs --external-prefix\" \"node scripts/dev-electron-main.mjs --external-prefix\"",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev:gateway-example": "node examples/gateway-server/server.mjs",
    "dev:desktop": "npm run dev:electron",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:pages": "npm run build:web",
    "preview:pages": "vite preview --host 0.0.0.0 --port 4173",
    "build:desktop": "npm run build:web",
    "release:verify": "node scripts/verify-electron-release.mjs",
    "package:win": "node scripts/release-electron.mjs",
    "release:win": "node scripts/release-electron.mjs --publish",
    "dist": "npm run package:win",
    "dist:win": "npm run package:win",
    "dist:publish": "npm run release:win",
    "preview": "vite preview",
    "start:gateway": "tsx server/src/index.ts",
    "typecheck:gateway": "tsc --pretty false --noEmit -p server/tsconfig.server.json",
    "start:electron": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "test:security": "node scripts/test-security.mjs",
    "test:e2ee": "node scripts/test-e2ee.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/s3-request-presigner": "^3.893.0",
    "@supabase/supabase-js": "^2.99.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.6.2",
    "ioredis": "^5.10.0",
    "mediasoup": "^3.19.18",
    "mediasoup-client": "^3.18.7",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@tanstack/react-query": "^5.90.21",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "dexie": "^4.3.0",
    "electron": "^40.4.0",
    "electron-builder": "^26.8.1",
    "emoji-picker-react": "^4.18.0",
    "gsap": "^3.14.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0",
    "terser": "^5.46.0",
    "twemoji": "^14.0.2",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  },
  "build": {
    "afterPack": "scripts/electron-after-pack.cjs",
    "appId": "com.mackstony.messly",
    "productName": "Messly",
    "artifactName": "messly-setup.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "copyright": "Copyright (c) 2026 Marco",
    "asar": true,
    "compression": "normal",
    "removePackageScripts": true,
    "buildDependenciesFromSource": false,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/assets/icons/app/messly-tray.svg",
      "src/assets/icons/app/*.svg",
      "src/assets/icons/app/*.png",
      "src/assets/icons/ui/messly.svg",
      "assets/icons/messly.ico",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/README*",
      "!**/CHANGELOG*",
      "!**/{test,tests}/**",
      "!**/__tests__/**",
      "!**/*.d.ts",
      "!**/*.tsbuildinfo",
      "!**/.env*",
      "!**/*.log",
      "!server/**",
      "!scripts/**",
      "!examples/**",
      "!release/**",
      "!.temp/**",
      "!coverage/**",
      "!**/.cache/**",
      "!**/node_modules/**/{test,tests,__tests__,example,examples,benchmark,benchmarks,docs,doc}/**",
      "!**/node_modules/**/README*",
      "!**/node_modules/**/CHANGELOG*"
    ],
    "icon": "icons/messly.ico",
    "protocols": [
      {
        "name": "Messly",
        "schemes": [
          "messly"
        ]
      }
    ],
    "electronLanguages": [
      "en-US",
      "pt-BR"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "appId": "com.mackstony.messly",
      "executableName": "Messly",
      "icon": "icons/messly.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Messly",
      "uninstallDisplayName": "Messly",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerIcon": "icons/messly.ico",
      "uninstallerIcon": "icons/messly.ico",
      "installerHeaderIcon": "icons/messly.ico",
      "include": "scripts/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "1blayze",
        "repo": "Messly-updates"
      }
    ]
  }
}
